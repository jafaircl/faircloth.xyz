---
import Meta from "../components/Meta.astro";
import "../styles/global.css";
import { formatFrontmatterDate } from "../utils";

const { frontmatter } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Meta title={frontmatter.title} description={frontmatter.description} />
  </head>
  <body>
    <header>
      <a href="/"><span>&#8592;&nbsp;</span>Home</a>
    </header>
    <main>
      <h1>{frontmatter.title}</h1>
      <p>
        {formatFrontmatterDate(frontmatter.date)}
      </p>
      <slot />
    </main>
    <style>
      main {
        h1,
        h2,
        h3,
        h4,
        h5,
        h6,
        p,
        pre {
          margin: 1.5rem 0;
        }

        pre {
          padding: 1.5rem;
          border-radius: 5px;
          overflow-x: auto;
        }
      }
    </style>
  </body>
</html>

---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { formatFrontmatterDate, estimateReadingTime } from '../utils';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  image?: string;
  body: string;
  slug?: string;
}

const { title, description, date, tags, image, body, slug } = Astro.props;
const readingTime = estimateReadingTime(body);
---

<BaseLayout title={title} description={description} image={image}>
  <Header />
  <main>
    <article class="blog-post" transition:name={slug ? `card-${slug}` : undefined}>
      <header class="post-header">
        <a href="/blog" class="back-link">&larr; Back to blog</a>
        <h1 transition:name={slug ? `card-title-${slug}` : undefined}>{title}</h1>
        <div class="post-meta">
          <time datetime={date.toISOString()} transition:name={slug ? `card-date-${slug}` : undefined}>{formatFrontmatterDate(date)}</time>
          <span class="separator">&middot;</span>
          <span>{readingTime} min read</span>
        </div>
        {tags.length > 0 && (
          <div class="post-tags" transition:name={slug ? `card-tags-${slug}` : undefined}>
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>
      <div class="prose" transition:animate="fade">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-post {
    padding-bottom: 3rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-fg-muted);
    font-size: 0.875rem;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-header h1 {
    margin-top: 0;
    font-size: 2.25rem;
    line-height: 1.2;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-fg-muted);
    font-size: 0.875rem;
    margin-top: 0.75rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background-color: var(--color-card);
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
  }
</style>

---
import Meta from "../components/Meta.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Meta title={title} description={description} image={image} includeSiteName={false} />
  </head>
  <body class="print-layout">
    <slot />
  </body>
</html>

<style>
  .print-layout {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
  }
</style>

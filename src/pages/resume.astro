---
import ResumeDocument from "../components/ResumeDocument.astro";
import StandardLayout from "../layouts/StandardLayout.astro";
---

<StandardLayout
  title="Resume"
  description="Jonathan Faircloth - Senior Software Engineer in Raleigh, NC"
>
  <section class="resume-page">
    <div class="resume-actions no-print">
      <a class="resume-action primary" href="/resume-print">
        Open Print View
      </a>
      <a class="resume-action" href="/jonathan-faircloth-resume.txt" download>
        Download TXT
      </a>
    </div>

    <ResumeDocument />
  </section>
</StandardLayout>

<style>
  .resume-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .resume-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    background: transparent;
    color: var(--color-fg-muted);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }

  .resume-action:hover {
    color: var(--color-fg);
    border-color: var(--color-fg-muted);
  }

  .resume-action.primary {
    background: var(--color-fg);
    border-color: var(--color-fg);
    color: var(--color-bg);
  }

  .resume-action.primary:hover {
    opacity: 0.92;
    color: var(--color-bg);
  }

  @media print {
    .no-print {
      display: none !important;
    }

    :global(.site-header),
    :global(.site-footer) {
      display: none !important;
    }

    :global(main) {
      max-width: none;
      padding: 0;
    }
  }
</style>

---
import { formatFrontmatterDate } from "../utils";

interface Props {
  title: string;
  body: string;
  href: string;
  date: string | Date;
  tags?: string[];
  slug?: string;
}

const { href, title, body, date, tags = [], slug } = Astro.props;
---

<a href={href} class="card" transition:name={slug ? `card-${slug}` : undefined}>
  <div class="card-content">
    <h3 class="card-title" transition:name={slug ? `card-title-${slug}` : undefined}>{title}</h3>
    <p class="card-body" transition:name={slug ? `card-desc-${slug}` : undefined}>{body}</p>
    <div class="card-footer">
      <time datetime={new Date(date).toISOString()} transition:name={slug ? `card-date-${slug}` : undefined}>{formatFrontmatterDate(date)}</time>
      {tags.length > 0 && (
        <div class="card-tags" transition:name={slug ? `card-tags-${slug}` : undefined}>
          {tags.slice(0, 3).map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
  <span class="arrow">&rarr;</span>
</a>

<style>
  .card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-card);
    color: var(--color-fg);
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .card:hover {
    background-color: var(--color-card-hover);
    border-color: var(--color-fg-muted);
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.4;
  }

  .card-body {
    margin: 0.375rem 0 0;
    font-size: 0.875rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-fg-muted);
  }

  .card-tags {
    display: flex;
    gap: 0.375rem;
  }

  .tag {
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    font-size: 0.7rem;
  }

  .arrow {
    font-size: 1.25rem;
    color: var(--color-fg-muted);
    margin-left: 1rem;
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .card:hover .arrow {
    transform: translateX(4px);
  }
</style>
